{
  "name": "rongyixing-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "build:workspace": "pnpm --filter @ryx/shared-types build && pnpm --filter @ryx/api build && pnpm --filter @ryx/mock build",
    "dev:h5": "pnpm build:workspace && pnpm --filter @ryx/h5 dev",
    "dev:h5:mock": "pnpm build:workspace && VITE_API_MODE=mock pnpm --filter @ryx/h5 dev",
    "dev:h5:test": "pnpm --filter @ryx/h5 dev --mode staging",
    "dev:web": "pnpm --filter @ryx/web dev",
    "build": "pnpm -r build",
    "extract-methods": "pnpm --filter @ryx/api extract-methods",
    "diff-jyx-methods": "node packages/api/scripts/diff-jyx-methods.mjs",
    "analyze-ryx-scope": "node packages/api/scripts/analyze-ryx-scope.mjs",
    "analyze-ryx-pages": "node packages/api/scripts/analyze-ryx-pages.mjs",
    "check:mock-coverage": "pnpm --filter @ryx/mock build && node packages/api/scripts/check-mock-coverage.mjs",
    "verify:mock": "pnpm --filter @ryx/shared-types build && pnpm --filter @ryx/api build && pnpm --filter @ryx/mock build && node packages/api/scripts/verify-mock.mjs",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "pnpm audit"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.3"
  }
}
