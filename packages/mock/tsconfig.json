{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "noEmit": false,
    "composite": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../shared-types" },
    { "path": "../api" }
  ],
  "exclude": ["src/**/*.test.ts"]
}
